---
import Container from '../common/Container.astro'

const stats = [
  { value: '5+', label: 'Лет на рынке' },
  { value: '50+', label: 'Реализованных проектов' },
  { value: '98%', label: 'Довольных клиентов' },
  { value: '10', label: 'Средний срок разработки, дней' },
]
---

<Container id="stats" className="section-gradient-reverse">
  <div class="grid grid-cols-2 md:grid-cols-4 gap-8 max-w-4xl mx-auto">
    {stats.map((s) => (
      <div class="text-center group">
        <div
          class="text-4xl md:text-5xl font-extrabold mb-2 transition-all duration-300 group-hover:scale-110"
          style="color: var(--accent)"
        >
          {s.value}
        </div>
        <div class="text-sm font-medium" style="color: var(--text-secondary)">{s.label}</div>
      </div>
    ))}
  </div>
</Container>