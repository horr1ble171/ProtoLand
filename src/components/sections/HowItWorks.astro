---
import Container from '../common/Container.astro'

const steps = [
  { num: '1', title: 'Выберите тему', desc: 'Переключайте светлую и тёмную версию, подбирайте акцентный цвет.' },
  { num: '2', title: 'Оцените секции', desc: 'Изучите типовые блоки: преимущества, отзывы, форму, табы и аккордеон.' },
  { num: '3', title: 'Настройте контент', desc: 'Все тексты — примеры. Вы сможете заменить их на свои.' },
  { num: '4', title: 'Закажите разработку', desc: 'Свяжитесь с нами, и мы превратим шаблон в готовый сайт.' },
]
---

<Container id="how-it-works" className="section-gradient">
  <div class="text-center mb-12">
    <h2 class="text-3xl md:text-4xl font-bold mb-4" style="color: var(--text-primary)">Как это работает</h2>
    <p class="text-lg max-w-2xl mx-auto" style="color: var(--text-secondary)">
      Всего 4 шага от знакомства до готового проекта
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-4 gap-6 relative">
    <div class="hidden md:block absolute top-8 left-[12.5%] right-[12.5%] h-0.5" style="background: linear-gradient(to right, var(--accent), color-mix(in srgb, var(--accent) 30%, transparent))"></div>
    {
      steps.map((step, i) => (
        <div class="text-center group">
          <div
            class="relative w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-5 text-xl font-bold text-[var(--text-on-accent)] transition-all duration-300 group-hover:scale-110 group-hover:shadow-lg"
            style="background: linear-gradient(135deg, var(--accent), var(--accent-hover)); box-shadow: 0 4px 16px var(--accent-glow)"
          >
            {step.num}
          </div>
          <h3 class="text-lg font-bold mb-2 transition-colors duration-200 group-hover:text-[var(--accent)]" style="color: var(--text-primary)">{step.title}</h3>
          <p class="text-sm leading-relaxed max-w-[240px] md:mx-auto" style="color: var(--text-secondary)">{step.desc}</p>
        </div>
      ))
    }
  </div>
</Container>