---
import Container from '../common/Container.astro'
import Icon from '../UI/Icon.astro'
import type { IconName } from '../UI/Icon.astro'

interface Feature {
  icon: IconName
  title: string
  subtitle: string
}

const features: Feature[] = [
  {
    icon: 'palette',
    title: 'Гибкая настройка цветов',
    subtitle: 'Светлая и тёмная темы, три акцентных цвета — подберите сочетание, которое подходит вашему бренду.',
  },
  {
    icon: 'devices',
    title: 'Адаптив под любые устройства',
    subtitle: 'Корректное отображение на всех экранах — от мобильных телефонов до широкоформатных мониторов.',
  },
  {
    icon: 'bolt',
    title: 'Скорость загрузки 100/100',
    subtitle: 'Оптимизированный код и статическая генерация обеспечивают максимальную производительность.',
  },
  {
    icon: 'lock',
    title: 'TypeScript + строгая типизация',
    subtitle: 'Надёжный и поддерживаемый код с минимальным риском ошибок при разработке.',
  },
]
---

<Container id="features">
  <div class="text-center mb-12">
    <h2 class="text-3xl md:text-4xl font-bold mb-4" style="color: var(--text-primary)">Возможности</h2>
    <p class="text-lg max-w-2xl mx-auto" style="color: var(--text-secondary)">
      Всё, что нужно для современного лендинга — из коробки
    </p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
    {
      features.map((f) => (
        <div
          class="bg-[var(--bg-card)] rounded-2xl p-6 card-shadow transition-all duration-300 border border-[var(--border)]"
        >
          <div class="mb-4" style="color: var(--accent)">
            <Icon name={f.icon} size={36} />
          </div>
          <h3 class="text-xl font-bold mb-2" style="color: var(--text-primary)">{f.title}</h3>
          <p class="text-base" style="color: var(--text-secondary)">{f.subtitle}</p>
        </div>
      ))
    }
  </div>
</Container>
