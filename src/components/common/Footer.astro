---
const year = new Date().getFullYear()

const socialLinks = [
  { label: 'Telegram', href: '#' },
  { label: 'WhatsApp', href: '#' },
  { label: 'GitHub', href: '#' },
]
---

<footer
  class="border-t py-12 mt-0"
  style="background-color: var(--bg-secondary); border-color: var(--border)"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-3">
        <img src="/logo.png" alt="ProtoLand" class="h-10 w-auto rounded-xl border-2" style="border-color: var(--border)" />
        <div>
          <span class="text-sm font-semibold block" style="color: var(--text-primary)">ProtoLand</span>
          <span class="text-xs" style="color: var(--text-secondary)">
            &copy; {year} Демо-шаблон. Все права защищены.
          </span>
        </div>
      </div>
      <div class="flex gap-2">
        {socialLinks.map((link) => (
          <a
            href={link.href}
            class="px-4 py-2 text-sm font-medium rounded-lg transition-all duration-200 hover:text-[var(--accent)] hover:bg-[var(--accent)]/5"
            style="color: var(--text-secondary)"
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>
    <div class="mt-8 pt-6 border-t text-center" style="border-color: var(--border)">
      <p class="text-xs" style="color: var(--accent)">
        <a href="https://horr1ble.space/" target="_blank" rel="noopener noreferrer" class="font-semibold transition-all duration-200 hover:opacity-80 hover:underline">Разработка horr1ble</a>
      </p>
    </div>
  </div>
</footer>