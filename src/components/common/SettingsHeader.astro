---
import ThemeSwitcher from '../ThemeSwitcher/ThemeSwitcher.astro'

const navLinks = [
  { href: '#settings-theme', label: 'Оформление', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>' },
  { href: '#settings-color', label: 'Цвет', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M8 10.5C8 11.3284 7.32843 12 6.5 12C5.67157 12 5 11.3284 5 10.5C5 9.67157 5.67157 9 6.5 9C7.32843 9 8 9.67157 8 10.5Z" fill="currentColor"/><path d="M10.5 8C11.3284 8 12 7.32843 12 6.5C12 5.67157 11.3284 5 10.5 5C9.67157 5 9 5.67157 9 6.5C9 7.32843 9.67157 8 10.5 8Z" fill="currentColor"/><path d="M17 6.5C17 7.32843 16.3284 8 15.5 8C14.6716 8 14 7.32843 14 6.5C14 5.67157 14.6716 5 15.5 5C16.3284 5 17 5.67157 17 6.5Z" fill="currentColor"/><path d="M7.5 17C8.32843 17 9 16.3284 9 15.5C9 14.6716 8.32843 14 7.5 14C6.67157 14 6 14.6716 6 15.5C6 16.3284 6.67157 17 7.5 17Z" fill="currentColor"/><path fill-rule="evenodd" clip-rule="evenodd" d="M1 12C1 5.92487 5.92487 1 12 1C17.9712 1 23 5.34921 23 11V11.0146C23 11.543 23.0001 12.4458 22.6825 13.4987C21.8502 16.2575 18.8203 16.9964 16.4948 16.4024C16.011 16.2788 15.5243 16.145 15.0568 16.0107C14.2512 15.7791 13.5177 16.4897 13.6661 17.2315L13.9837 18.8197L14.0983 19.5068C14.3953 21.289 13.0019 23.1015 11.0165 22.8498C7.65019 22.423 5.11981 21.1007 3.43595 19.1329C1.75722 17.171 1 14.6613 1 12ZM12 3C7.02944 3 3 7.02944 3 12C3 14.2854 3.64673 16.303 4.95555 17.8326C6.25924 19.3561 8.3 20.4894 11.2681 20.8657C11.7347 20.9249 12.2348 20.4915 12.1255 19.8356L12.0163 19.1803L11.7049 17.6237C11.2467 15.3325 13.4423 13.4657 15.6093 14.0885C16.0619 14.2186 16.529 14.3469 16.9897 14.4646C18.7757 14.9208 20.3744 14.2249 20.7677 12.921C20.997 12.161 21 11.5059 21 11C21 6.65079 17.0745 3 12 3Z" fill="currentColor"/></svg>' },
  { href: '#settings-font', label: 'Шрифт', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 7V4h16v3"/><path d="M9 20h6"/><path d="M12 4v16"/></svg>' },
  { href: '#settings-effects', label: 'Эффекты', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/><line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/><line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/><line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="17" y1="16" x2="23" y2="16"/></svg>' },
  { href: '#settings-text', label: 'Текст', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>' },
  { href: '#settings-export', label: 'Экспорт', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>' },
]
---

<header
  class="sticky top-0 z-50 backdrop-blur-xl border-b transition-colors duration-300"
  style="background-color: var(--header-bg); border-color: var(--border)"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-14 md:h-16">
      <a href="/" class="flex items-center gap-2.5 group shrink-0">
        <div class="relative">
          <img src="/logo.png" alt="ProtoLand" class="h-8 md:h-9 w-auto rounded-lg border-2 transition-all duration-300 group-hover:border-[var(--accent)]" style="border-color: var(--border)" />
        </div>
        <span class="text-base font-bold tracking-tight hidden sm:inline transition-colors duration-200 group-hover:text-[var(--accent)]" style="color: var(--text-primary)">ProtoLand</span>
      </a>

      <nav class="hidden md:flex items-center gap-0.5">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class="relative px-3 py-1.5 text-xs font-medium rounded-lg transition-all duration-200 hover:text-[var(--accent)] hover:bg-[var(--accent)]/5 flex items-center gap-1.5 whitespace-nowrap"
              style="color: var(--text-secondary)"
            >
              <span set:html={link.icon} />
              {link.label}
            </a>
          ))
        }
      </nav>

      <div class="flex items-center gap-2">
        <ThemeSwitcher />
        <button
          id="settings-menu-btn"
          class="md:hidden w-8 h-8 relative flex items-center justify-center rounded-lg transition-all duration-200 border hover:border-[var(--accent)]"
          style="background-color: var(--bg-card); border-color: var(--border); color: var(--text-secondary)"
          aria-label="Меню"
          aria-expanded="false"
        >
          <span class="absolute w-3.5 h-0.5 rounded-full transition-all duration-300" style="background-color: currentColor; transform: translateY(-3.5px)" id="settings-menu-line-1"></span>
          <span class="absolute w-3.5 h-0.5 rounded-full transition-all duration-300" style="background-color: currentColor" id="settings-menu-line-2"></span>
          <span class="absolute w-3.5 h-0.5 rounded-full transition-all duration-300" style="background-color: currentColor; transform: translateY(3.5px)" id="settings-menu-line-3"></span>
        </button>
      </div>
    </div>
  </div>

  <div
    id="settings-mobile-menu"
    class="md:hidden overflow-hidden transition-all duration-300 max-h-0 border-t"
    style="background-color: var(--bg-card); border-color: var(--border)"
  >
    <nav class="flex flex-col gap-0.5 px-4 py-3">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="px-4 py-2.5 text-sm font-medium rounded-lg transition-all duration-200 hover:text-[var(--accent)] hover:bg-[var(--accent)]/5 active:scale-[0.98] flex items-center gap-2"
            style="color: var(--text-secondary)"
          >
            <span set:html={link.icon} />
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<script>
  const menuBtn = document.getElementById('settings-menu-btn')
  const mobileMenu = document.getElementById('settings-mobile-menu')
  const line1 = document.getElementById('settings-menu-line-1')
  const line2 = document.getElementById('settings-menu-line-2')
  const line3 = document.getElementById('settings-menu-line-3')

  function openMenu(): void {
    mobileMenu?.classList.remove('max-h-0')
    mobileMenu?.classList.add('max-h-80')
    menuBtn?.setAttribute('aria-expanded', 'true')
    if (line1) line1.style.transform = 'translateY(0) rotate(45deg)'
    if (line2) line2.style.opacity = '0'
    if (line2) line2.style.transform = 'scaleX(0)'
    if (line3) line3.style.transform = 'translateY(0) rotate(-45deg)'
  }

  function closeMenu(): void {
    mobileMenu?.classList.remove('max-h-80')
    mobileMenu?.classList.add('max-h-0')
    menuBtn?.setAttribute('aria-expanded', 'false')
    if (line1) line1.style.transform = 'translateY(-3.5px) rotate(0deg)'
    if (line2) line2.style.opacity = '1'
    if (line2) line2.style.transform = 'scaleX(1)'
    if (line3) line3.style.transform = 'translateY(3.5px) rotate(0deg)'
  }

  menuBtn?.addEventListener('click', () => {
    const isOpen = menuBtn.getAttribute('aria-expanded') === 'true'
    if (isOpen) closeMenu()
    else openMenu()
  })

  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu)
  })

  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement
    if (!target.closest('header') && menuBtn?.getAttribute('aria-expanded') === 'true') {
      closeMenu()
    }
  })
</script>
