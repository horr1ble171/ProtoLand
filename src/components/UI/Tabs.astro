---
export interface Tab {
  label: string
  content: string
}

export interface Props {
  tabs: Tab[]
}

const { tabs } = Astro.props
---

<div class="tabs" data-tabs>
  <div class="flex flex-wrap gap-2 mb-6" role="tablist">
    {
      tabs.map((tab, i) => (
        <button
          class="tab-btn px-5 py-2.5 rounded-lg font-medium transition-all duration-200"
          class:list={{
            'bg-[var(--accent)] text-[var(--text-on-accent)]': i === 0,
            'bg-[var(--bg-card)] border border-[var(--border)]': i !== 0,
          }}
          style={i !== 0 ? 'color: var(--text-secondary)' : ''}
          role="tab"
          data-tab-btn
        >
          {tab.label}
        </button>
      ))
    }
  </div>

  {
    tabs.map((tab, i) => (
      <div
        class="tab-panel p-6 rounded-xl bg-[var(--bg-card)] border border-[var(--border)] card-shadow"
        style={`color: var(--text-secondary); display: ${i === 0 ? 'block' : 'none'}`}
        data-tab-panel
      >
        {tab.content}
      </div>
    ))
  }
</div>

<script>
  const BASE_INACTIVE = 'tab-btn px-5 py-2.5 rounded-lg font-medium transition-all duration-200 bg-[var(--bg-card)] border border-[var(--border)]'
  const BASE_ACTIVE = 'tab-btn px-5 py-2.5 rounded-lg font-medium transition-all duration-200 bg-[var(--accent)] text-[var(--text-on-accent)]'

  document.querySelectorAll('[data-tabs]').forEach((tabs) => {
    const buttons = tabs.querySelectorAll('[data-tab-btn]')
    const panels = tabs.querySelectorAll('[data-tab-panel]')

    buttons.forEach((btn, index) => {
      btn.addEventListener('click', () => {
        panels.forEach((p) => { (p as HTMLElement).style.display = 'none' })
        buttons.forEach((b) => {
          b.className = BASE_INACTIVE
          ;(b as HTMLElement).style.color = 'var(--text-secondary)'
        })
        ;(panels[index] as HTMLElement).style.display = 'block'
        buttons[index].className = BASE_ACTIVE
        ;(buttons[index] as HTMLElement).style.color = ''
      })
    })
  })
</script>
