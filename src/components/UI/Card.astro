---
export interface Props {
  title: string
  subtitle?: string
  icon?: string
}

const { title, subtitle, icon } = Astro.props
---

<div class="bg-[var(--bg-card)] rounded-2xl p-6 shadow-[var(--shadow)] hover:shadow-[var(--shadow-hover)] transition-all duration-300 border border-[var(--border)]">
  {icon && <div class="text-4xl mb-4">{icon}</div>}
  <h3 class="text-xl font-bold mb-2" style="color: var(--text-primary)">{title}</h3>
  {subtitle && <p class="text-base" style="color: var(--text-secondary)">{subtitle}</p>}
</div>
