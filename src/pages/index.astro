---
import BaseLayout from '../layouts/BaseLayout.astro'
import Header from '../components/common/Header.astro'
import Hero from '../components/sections/Hero.astro'
import Features from '../components/sections/Features.astro'
import Stats from '../components/sections/Stats.astro'
import HowItWorks from '../components/sections/HowItWorks.astro'
import Examples from '../components/sections/Examples.astro'
import Testimonials from '../components/sections/Testimonials.astro'
import Pricing from '../components/sections/Pricing.astro'
import Portfolio from '../components/sections/Portfolio.astro'
import ContactForm from '../components/sections/ContactForm.astro'
import Footer from '../components/common/Footer.astro'
---

<BaseLayout>
  <Header />
  <main>
    <Hero />
    <div class="observe-fade opacity-0"><Features /></div>
    <div class="observe-fade opacity-0"><Stats /></div>
    <div class="observe-fade opacity-0"><HowItWorks /></div>
    <div class="observe-fade opacity-0"><Examples /></div>
    <div class="observe-fade opacity-0"><Testimonials /></div>
    <div class="observe-fade opacity-0"><Pricing /></div>
    <div class="observe-fade opacity-0"><Portfolio /></div>
    <div class="observe-fade opacity-0"><ContactForm /></div>
  </main>
  <Footer />
</BaseLayout>
