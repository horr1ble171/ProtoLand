---
import BaseLayout from '../layouts/BaseLayout.astro'
import SettingsHeader from '../components/common/SettingsHeader.astro'

const presetColors = [
  { value: 'red', label: 'Красный', light: '#e53935', dark: '#ff5252' },
  { value: 'violet', label: 'Фиолетовый', light: '#7c3aed', dark: '#a78bfa' },
  { value: 'indigo', label: 'Индиго', light: '#4f46e5', dark: '#818cf8' },
  { value: 'sky', label: 'Небесный', light: '#0284c7', dark: '#38bdf8' },
  { value: 'cyan', label: 'Циан', light: '#0891b2', dark: '#22d3ee' },
  { value: 'teal', label: 'Бирюзовый', light: '#0d9488', dark: '#2dd4bf' },
  { value: 'lime', label: 'Лайм', light: '#65a30d', dark: '#a3e635' },
  { value: 'orange', label: 'Оранжевый', light: '#ea580c', dark: '#fb923c' },
  { value: 'pink', label: 'Розовый', light: '#db2777', dark: '#f472b6' },
  { value: 'rose', label: 'Роза', light: '#e11d48', dark: '#fb7185' },
  { value: 'fuchsia', label: 'Фуксия', light: '#c026d3', dark: '#e879f9' },
]
---

<BaseLayout title="ProtoLand — Настройка лендинга" description="Настройте внешний вид лендинга: выберите тему и акцентный цвет.">
  <SettingsHeader />
  <div class="min-h-screen section-gradient pt-20" style="color: var(--text-primary)">
    <div class="max-w-3xl mx-auto px-4 py-12">

      <div class="flex items-start sm:items-center gap-3 sm:gap-4 mb-2">
        <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-xl sm:rounded-2xl flex items-center justify-center shrink-0 text-base sm:text-lg" style="background-color: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent)">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="sm:w-5 sm:h-5"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 8.92a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 8.92 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1.08 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1.08z"/></svg>
        </div>
        <div class="min-w-0">
          <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold leading-tight">Настройка лендинга</h1>
          <p class="text-xs sm:text-sm mt-0.5 sm:mt-1" style="color: var(--text-secondary)">
            Все изменения применяются сразу и сохраняются в браузере
          </p>
        </div>
      </div>

      <div id="customize-app" class="space-y-5 mt-10">
        <!-- Theme -->
        <div id="settings-theme" class="rounded-2xl p-6 border card-shadow hover-lift" style="background-color: var(--bg-card); border-color: var(--border)">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background-color: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent)">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
            </div>
            <h2 class="text-lg font-bold">Тема оформления</h2>
          </div>
          <div class="flex gap-3">
            <button class="theme-btn flex-1 flex items-center justify-center gap-3 px-6 py-4 rounded-xl border-2 font-semibold transition-all duration-200" data-theme-value="light">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
              Светлая
            </button>
            <button class="theme-btn flex-1 flex items-center justify-center gap-3 px-6 py-4 rounded-xl border-2 font-semibold transition-all duration-200" data-theme-value="dark">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
              Тёмная
            </button>
          </div>
        </div>

        <!-- Accent Color -->
        <div id="settings-color" class="rounded-2xl p-6 border card-shadow hover-lift" style="background-color: var(--bg-card); border-color: var(--border)">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background-color: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent)">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M8 10.5C8 11.3284 7.32843 12 6.5 12C5.67157 12 5 11.3284 5 10.5C5 9.67157 5.67157 9 6.5 9C7.32843 9 8 9.67157 8 10.5Z" fill="currentColor"/><path d="M10.5 8C11.3284 8 12 7.32843 12 6.5C12 5.67157 11.3284 5 10.5 5C9.67157 5 9 5.67157 9 6.5C9 7.32843 9.67157 8 10.5 8Z" fill="currentColor"/><path d="M17 6.5C17 7.32843 16.3284 8 15.5 8C14.6716 8 14 7.32843 14 6.5C14 5.67157 14.6716 5 15.5 5C16.3284 5 17 5.67157 17 6.5Z" fill="currentColor"/><path d="M7.5 17C8.32843 17 9 16.3284 9 15.5C9 14.6716 8.32843 14 7.5 14C6.67157 14 6 14.6716 6 15.5C6 16.3284 6.67157 17 7.5 17Z" fill="currentColor"/><path fill-rule="evenodd" clip-rule="evenodd" d="M1 12C1 5.92487 5.92487 1 12 1C17.9712 1 23 5.34921 23 11V11.0146C23 11.543 23.0001 12.4458 22.6825 13.4987C21.8502 16.2575 18.8203 16.9964 16.4948 16.4024C16.011 16.2788 15.5243 16.145 15.0568 16.0107C14.2512 15.7791 13.5177 16.4897 13.6661 17.2315L13.9837 18.8197L14.0983 19.5068C14.3953 21.289 13.0019 23.1015 11.0165 22.8498C7.65019 22.423 5.11981 21.1007 3.43595 19.1329C1.75722 17.171 1 14.6613 1 12ZM12 3C7.02944 3 3 7.02944 3 12C3 14.2854 3.64673 16.303 4.95555 17.8326C6.25924 19.3561 8.3 20.4894 11.2681 20.8657C11.7347 20.9249 12.2348 20.4915 12.1255 19.8356L12.0163 19.1803L11.7049 17.6237C11.2467 15.3325 13.4423 13.4657 15.6093 14.0885C16.0619 14.2186 16.529 14.3469 16.9897 14.4646C18.7757 14.9208 20.3744 14.2249 20.7677 12.921C20.997 12.161 21 11.5059 21 11C21 6.65079 17.0745 3 12 3Z" fill="currentColor"/></svg>
            </div>
            <h2 class="text-lg font-bold">Акцентный цвет</h2>
          </div>

          <div class="mb-6">
            <p class="text-xs font-medium mb-3 uppercase tracking-wider" style="color: var(--text-secondary)">Быстрый выбор</p>
            <div class="flex gap-2.5 flex-wrap">
              {presetColors.map((c) => (
                <button
                  class="preset-btn w-10 h-10 rounded-xl border-2 transition-all duration-200 hover:scale-110 hover:shadow-lg"
                  data-accent-value={c.value}
                  aria-label={c.label}
                  title={c.label}
                  style="background-color: var(--accent-color)"
                  data-light={c.light}
                  data-dark={c.dark}
                />
              ))}
            </div>
          </div>

          <div class="border-t pt-5" style="border-color: var(--border)">
            <p class="text-xs font-medium mb-3 uppercase tracking-wider" style="color: var(--text-secondary)">Произвольный цвет</p>
            <div class="flex items-center gap-4">
              <input
                type="color"
                id="color-picker"
                class="w-14 h-14 rounded-xl border-2 cursor-pointer transition-all duration-200 hover:scale-105 [&::-webkit-color-swatch-wrapper]:p-0 [&::-webkit-color-swatch]:border-none [&::-webkit-color-swatch]:rounded-lg"
                style="border-color: var(--border); background: none"
                value="#e53935"
              />
              <div class="flex-1">
                <label for="hex-input" class="text-xs font-medium block mb-1.5" style="color: var(--text-secondary)">HEX</label>
                <input
                  type="text"
                  id="hex-input"
                  class="w-full px-4 py-2.5 rounded-xl border text-sm outline-none transition-colors"
                  style="background-color: var(--bg-primary); color: var(--text-primary); border-color: var(--border); font-family: 'SF Mono', 'Fira Code', monospace"
                  placeholder="#e53935"
                  maxlength={7}
                />
              </div>
            </div>
          </div>
        </div>

        <!-- Font Settings -->
        <div id="settings-font" class="rounded-2xl p-6 border card-shadow hover-lift" style="background-color: var(--bg-card); border-color: var(--border)">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background-color: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent)">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 7V4h16v3"/><path d="M9 20h6"/><path d="M12 4v16"/></svg>
            </div>
            <h2 class="text-lg font-bold">Шрифт</h2>
          </div>

          <p class="text-xs font-medium mb-3 uppercase tracking-wider" style="color: var(--text-secondary)">Готовые шрифты</p>
          <div class="grid grid-cols-3 sm:grid-cols-4 gap-2 mb-6">
            <button class="font-btn flex flex-col items-center gap-1.5 px-3 py-3.5 rounded-xl border-2 font-semibold transition-all duration-200 text-sm" data-font-value="system">
              <span class="text-base">System</span>
              <span class="text-[10px] opacity-60">Системный</span>
            </button>
            <button class="font-btn flex flex-col items-center gap-1.5 px-3 py-3.5 rounded-xl border-2 font-semibold transition-all duration-200 text-sm" data-font-value="inter" style="font-family: Inter">
              <span class="text-base">Inter</span>
              <span class="text-[10px] opacity-60">Современный</span>
            </button>
            <button class="font-btn flex flex-col items-center gap-1.5 px-3 py-3.5 rounded-xl border-2 font-semibold transition-all duration-200 text-sm" data-font-value="roboto" style="font-family: Roboto">
              <span class="text-base">Roboto</span>
              <span class="text-[10px] opacity-60">Классика</span>
            </button>
            <button class="font-btn flex flex-col items-center gap-1.5 px-3 py-3.5 rounded-xl border-2 font-semibold transition-all duration-200 text-sm" data-font-value="playfair" style="font-family: 'Playfair Display'">
              <span class="text-base">Playfair</span>
              <span class="text-[10px] opacity-60">Премиум</span>
            </button>
            <button class="font-btn flex flex-col items-center gap-1.5 px-3 py-3.5 rounded-xl border-2 font-semibold transition-all duration-200 text-sm" data-font-value="montserrat" style="font-family: Montserrat">
              <span class="text-base">Montserrat</span>
              <span class="text-[10px] opacity-60">Современный</span>
            </button>
            <button class="font-btn flex flex-col items-center gap-1.5 px-3 py-3.5 rounded-xl border-2 font-semibold transition-all duration-200 text-sm" data-font-value="open-sans" style="font-family: 'Open Sans'">
              <span class="text-base">Open Sans</span>
              <span class="text-[10px] opacity-60">Универсальный</span>
            </button>
            <button class="font-btn flex flex-col items-center gap-1.5 px-3 py-3.5 rounded-xl border-2 font-semibold transition-all duration-200 text-sm" data-font-value="lato" style="font-family: Lato">
              <span class="text-base">Lato</span>
              <span class="text-[10px] opacity-60">Универсальный</span>
            </button>
            <button class="font-btn flex flex-col items-center gap-1.5 px-3 py-3.5 rounded-xl border-2 font-semibold transition-all duration-200 text-sm" data-font-value="nunito" style="font-family: Nunito">
              <span class="text-base">Nunito</span>
              <span class="text-[10px] opacity-60">Мягкий</span>
            </button>
            <button class="font-btn flex flex-col items-center gap-1.5 px-3 py-3.5 rounded-xl border-2 font-semibold transition-all duration-200 text-sm" data-font-value="poppins" style="font-family: Poppins">
              <span class="text-base">Poppins</span>
              <span class="text-[10px] opacity-60">Современный</span>
            </button>
            <button class="font-btn flex flex-col items-center gap-1.5 px-3 py-3.5 rounded-xl border-2 font-semibold transition-all duration-200 text-sm" data-font-value="raleway" style="font-family: Raleway">
              <span class="text-base">Raleway</span>
              <span class="text-[10px] opacity-60">Элегантный</span>
            </button>
            <button class="font-btn flex flex-col items-center gap-1.5 px-3 py-3.5 rounded-xl border-2 font-semibold transition-all duration-200 text-sm" data-font-value="ubuntu" style="font-family: Ubuntu">
              <span class="text-base">Ubuntu</span>
              <span class="text-[10px] opacity-60">Технический</span>
            </button>
            <button class="font-btn flex flex-col items-center gap-1.5 px-3 py-3.5 rounded-xl border-2 font-semibold transition-all duration-200 text-sm" data-font-value="oswald" style="font-family: Oswald">
              <span class="text-base">Oswald</span>
              <span class="text-[10px] opacity-60">Акцентный</span>
            </button>
          </div>

          <div class="border-t pt-5 mb-5" style="border-color: var(--border)">
            <p class="text-xs font-medium mb-3 uppercase tracking-wider" style="color: var(--text-secondary)">Свой шрифт из Google Fonts</p>
            <div class="flex gap-3">
              <input
                type="text"
                id="custom-font-input"
                class="flex-1 px-4 py-2.5 rounded-xl border text-sm outline-none transition-colors"
                style="background-color: var(--bg-primary); color: var(--text-primary); border-color: var(--border)"
                placeholder="Exo 2"
              />
              <button
                id="custom-font-apply"
                class="px-5 py-2.5 text-sm font-semibold rounded-xl transition-all duration-200 hover-lift"
                style="background-color: var(--accent); color: var(--text-on-accent)"
              >
                Применить
              </button>
            </div>
          </div>

          <div class="border-t pt-5" style="border-color: var(--border)">
            <p class="text-xs font-medium mb-3 uppercase tracking-wider" style="color: var(--text-secondary)">Насыщенность (weight)</p>
            <div class="flex flex-wrap gap-2" id="weight-presets">
              {[300, 400, 500, 600, 700, 800, 900].map((w) => (
                <button
                  class="weight-btn px-4 py-2 rounded-lg text-sm font-semibold border-2 transition-all duration-200"
                  data-weight-value={w}
                  style="background-color: var(--bg-secondary); color: var(--text-primary); border-color: transparent"
                >{w}</button>
              ))}
            </div>
          </div>
        </div>

        <!-- Toggles -->
        <div id="settings-effects" class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-5">
          <div class="rounded-2xl p-5 border card-shadow hover-lift" style="background-color: var(--bg-card); border-color: var(--border)">
            <div class="flex items-center justify-between">
              <div class="flex items-start gap-3">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0" style="background-color: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent)">
                  <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                </div>
                <div>
                  <p class="font-semibold text-sm" style="color: var(--text-primary)">Анимации</p>
                  <p class="text-xs mt-0.5" style="color: var(--text-secondary)">Fade-in при скролле</p>
                </div>
              </div>
              <button id="anim-toggle" class="relative w-12 h-6 rounded-full transition-colors duration-200 shrink-0" style="background-color: var(--border)" role="switch" aria-checked="true">
                <span id="anim-knob" class="absolute top-0.5 left-0.5 w-5 h-5 rounded-full bg-white shadow transition-transform duration-200" style="transform: translateX(0)" />
              </button>
            </div>
          </div>

          <div class="rounded-2xl p-5 border card-shadow hover-lift" style="background-color: var(--bg-card); border-color: var(--border)">
            <div class="flex items-center justify-between">
              <div class="flex items-start gap-3">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0" style="background-color: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent)">
                  <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
                </div>
                <div>
                  <p class="font-semibold text-sm" style="color: var(--text-primary)">Тени блоков</p>
                  <p class="text-xs mt-0.5" style="color: var(--text-secondary)">Тени у карточек и секций</p>
                </div>
              </div>
              <button id="shadow-toggle" class="relative w-12 h-6 rounded-full transition-colors duration-200 shrink-0" style="background-color: var(--border)" role="switch" aria-checked="true">
                <span id="shadow-knob" class="absolute top-0.5 left-0.5 w-5 h-5 rounded-full bg-white shadow transition-transform duration-200" style="transform: translateX(0)" />
              </button>
            </div>
          </div>

          <div class="rounded-2xl p-5 border card-shadow hover-lift" style="background-color: var(--bg-card); border-color: var(--border)">
            <div class="flex items-center justify-between">
              <div class="flex items-start gap-3">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0" style="background-color: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent)">
                  <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>
                </div>
                <div>
                  <p class="font-semibold text-sm" style="color: var(--text-primary)">Кастомный скроллбар</p>
                  <p class="text-xs mt-0.5" style="color: var(--text-secondary)">Стилизованная полоса прокрутки</p>
                </div>
              </div>
              <button id="scrollbar-toggle" class="relative w-12 h-6 rounded-full transition-colors duration-200 shrink-0" style="background-color: var(--border)" role="switch" aria-checked="true">
                <span id="scrollbar-knob" class="absolute top-0.5 left-0.5 w-5 h-5 rounded-full bg-white shadow transition-transform duration-200" style="transform: translateX(0)" />
              </button>
            </div>
          </div>

          <div class="rounded-2xl p-5 border card-shadow hover-lift" style="background-color: var(--bg-card); border-color: var(--border)">
            <div class="flex items-center justify-between">
              <div class="flex items-start gap-3">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0" style="background-color: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent)">
                  <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                </div>
                <div>
                  <p class="font-semibold text-sm" style="color: var(--text-primary)">Скругление блоков</p>
                  <p class="text-xs mt-0.5" style="color: var(--text-secondary)">Радиус углов карточек и панелей</p>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <span id="radius-badge" class="text-xs font-semibold px-2 py-1 rounded-md" style="background-color: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent)">16px</span>
              </div>
            </div>
            <div class="mt-4 flex gap-2 flex-wrap" id="radius-presets">
              <button class="radius-btn flex-1 min-w-[60px] px-3 py-2 rounded-lg font-semibold text-xs transition-all duration-200 border-2" data-radius-value="0" style="background-color: var(--bg-secondary); color: var(--text-primary); border-color: transparent">0px</button>
              <button class="radius-btn flex-1 min-w-[60px] px-3 py-2 rounded-lg font-semibold text-xs transition-all duration-200 border-2" data-radius-value="8" style="background-color: var(--bg-secondary); color: var(--text-primary); border-color: transparent">8px</button>
              <button class="radius-btn flex-1 min-w-[60px] px-3 py-2 rounded-lg font-semibold text-xs transition-all duration-200 border-2" data-radius-value="16" style="background-color: var(--bg-secondary); color: var(--text-primary); border-color: transparent">16px</button>
              <button class="radius-btn flex-1 min-w-[60px] px-3 py-2 rounded-lg font-semibold text-xs transition-all duration-200 border-2" data-radius-value="custom" style="background-color: var(--bg-secondary); color: var(--text-primary); border-color: transparent">Своё</button>
            </div>
            <div id="radius-custom" class="hidden mt-3">
              <label class="flex items-center gap-3">
                <span class="text-xs font-medium shrink-0" style="color: var(--text-secondary)">px</span>
                <input type="range" id="radius-slider" min="0" max="32" value="16" class="flex-1 accent-[var(--accent)] cursor-pointer" />
                <output id="radius-value" class="text-sm font-mono font-semibold min-w-[2rem] text-right" style="color: var(--accent)">16</output>
              </label>
            </div>
          </div>
        </div>

        <!-- Smooth Scroll -->
        <div class="rounded-2xl p-5 border card-shadow hover-lift" style="background-color: var(--bg-card); border-color: var(--border)">
          <div class="flex items-center justify-between">
            <div class="flex items-start gap-3">
              <div class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0" style="background-color: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent)">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <div>
                <p class="font-semibold text-sm" style="color: var(--text-primary)">Плавный скролл</p>
                <p class="text-xs mt-0.5" style="color: var(--text-secondary)">Плавная прокрутка по якорям</p>
              </div>
            </div>
            <button id="smooth-scroll-toggle" class="relative w-12 h-6 rounded-full transition-colors duration-200 shrink-0" style="background-color: var(--accent)" role="switch" aria-checked="true">
              <span id="smooth-scroll-knob" class="absolute top-0.5 left-0.5 w-5 h-5 rounded-full bg-white shadow transition-transform duration-200" style="transform: translateX(24px)" />
            </button>
          </div>
        </div>

        <!-- Gradient Text -->
        <div id="settings-text" class="rounded-2xl p-6 border card-shadow" style="background-color: var(--bg-card); border-color: var(--border)">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0" style="background-color: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent)">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 7V4h16v3"/><path d="M9 20h6"/><path d="M12 4v16"/></svg>
            </div>
            <div class="flex-1">
              <h2 class="text-lg font-bold">Градиентный текст</h2>
              <p class="text-xs mt-0.5" style="color: var(--text-secondary)">Эффект градиента для заголовков</p>
            </div>
            <button id="gradient-toggle" class="relative w-12 h-6 rounded-full transition-colors duration-200 shrink-0" style="background-color: var(--border)" role="switch" aria-checked="false">
              <span id="gradient-knob" class="absolute top-0.5 left-0.5 w-5 h-5 rounded-full bg-white shadow transition-transform duration-200" style="transform: translateX(0)" />
            </button>
          </div>

          <div id="gradient-settings" class="hidden space-y-5">
            <div>
              <p class="text-xs font-medium mb-3 uppercase tracking-wider" style="color: var(--text-secondary)">Цвет 1 (от)</p>
              <div class="flex items-center gap-3">
                <input
                  type="color"
                  id="gradient-from-picker"
                  class="w-12 h-12 rounded-xl border-2 cursor-pointer transition-all duration-200 [&::-webkit-color-swatch-wrapper]:p-0 [&::-webkit-color-swatch]:border-none [&::-webkit-color-swatch]:rounded-lg"
                  style="border-color: var(--border); background: none"
                  value="#e53935"
                />
                <input
                  type="text"
                  id="gradient-from-hex"
                  class="flex-1 px-4 py-2.5 rounded-xl border text-sm outline-none transition-colors font-mono"
                  style="background-color: var(--bg-primary); color: var(--text-primary); border-color: var(--border)"
                  placeholder="#e53935"
                  maxlength={7}
                />
              </div>
            </div>

            <div>
              <p class="text-xs font-medium mb-3 uppercase tracking-wider" style="color: var(--text-secondary)">Цвет 2 (до)</p>
              <div class="flex items-center gap-3">
                <input
                  type="color"
                  id="gradient-to-picker"
                  class="w-12 h-12 rounded-xl border-2 cursor-pointer transition-all duration-200 [&::-webkit-color-swatch-wrapper]:p-0 [&::-webkit-color-swatch]:border-none [&::-webkit-color-swatch]:rounded-lg"
                  style="border-color: var(--border); background: none"
                  value="#c62828"
                />
                <input
                  type="text"
                  id="gradient-to-hex"
                  class="flex-1 px-4 py-2.5 rounded-xl border text-sm outline-none transition-colors font-mono"
                  style="background-color: var(--bg-primary); color: var(--text-primary); border-color: var(--border)"
                  placeholder="#c62828"
                  maxlength={7}
                />
              </div>
            </div>

            <div>
              <label class="flex items-center gap-3">
                <span class="text-xs font-medium shrink-0" style="color: var(--text-secondary)">Интенсивность</span>
                <input type="range" id="gradient-intensity-slider" min="0" max="100" value="70" class="flex-1 accent-[var(--accent)] cursor-pointer" />
                <output id="gradient-intensity-value" class="text-sm font-mono font-semibold min-w-[2.5rem] text-right" style="color: var(--accent)">70%</output>
              </label>
            </div>
          </div>
        </div>

        <!-- Reset -->
        <div id="settings-reset" class="rounded-2xl p-6 border card-shadow" style="background-color: var(--bg-card); border-color: var(--border)">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0" style="background-color: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent)">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
            </div>
            <div>
              <h2 class="text-lg font-bold">Сброс настроек</h2>
              <p class="text-xs mt-0.5" style="color: var(--text-secondary)">Вернуть все настройки по умолчанию</p>
            </div>
          </div>
          <button
            id="reset-btn"
            class="w-full py-3 text-base font-semibold rounded-xl transition-all duration-200 hover-lift"
            style="background: linear-gradient(135deg, #e53935, #c62828); color: #fff"
          >
            Сбросить всё
          </button>
        </div>

        <!-- Export / Import -->
        <div id="settings-export" class="rounded-2xl p-6 border card-shadow" style="background-color: var(--bg-card); border-color: var(--border)">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0" style="background-color: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent)">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            </div>
            <div>
              <h2 class="text-lg font-bold">Экспорт / Импорт</h2>
              <p class="text-xs mt-0.5" style="color: var(--text-secondary)">Сохраните настройки или перенесите на другой сайт</p>
            </div>
          </div>

          <div class="flex gap-1 mb-4 p-1 rounded-xl" style="background-color: var(--bg-secondary)">
            <button id="export-tab-btn" class="flex-1 py-2 text-sm font-semibold rounded-lg transition-all" style="background-color: var(--accent); color: var(--text-on-accent)">Экспорт</button>
            <button id="import-tab-btn" class="flex-1 py-2 text-sm font-semibold rounded-lg transition-all" style="background-color: transparent; color: var(--text-secondary)">Импорт</button>
          </div>

          <div id="export-panel">
            <p class="text-xs mb-3" style="color: var(--text-secondary)">
              Скопируйте JSON и отправьте разработчику.
            </p>
            <textarea
              id="export-json"
              rows={4}
              class="w-full px-4 py-3 rounded-xl border text-xs outline-none resize-y mb-3 transition-colors"
              style="background-color: var(--bg-primary); color: var(--text-primary); border-color: var(--border); font-family: 'SF Mono', 'Fira Code', monospace"
              readonly
            ></textarea>
            <div class="flex gap-3">
              <button
                id="export-btn"
                class="flex-1 py-2.5 text-sm font-semibold rounded-xl transition-all duration-200 hover-lift"
                style="background-color: var(--accent); color: var(--text-on-accent)"
              >
                Копировать
              </button>
              <button
                id="download-btn"
                class="flex-1 py-2.5 text-sm font-semibold rounded-xl border-2 transition-all duration-200 hover-lift"
                style="border-color: var(--accent); color: var(--accent)"
              >
                Скачать JSON
              </button>
            </div>
            <div id="export-toast" class="hidden mt-2 text-sm text-center font-medium py-2 px-4 rounded-lg" style="background-color: color-mix(in srgb, var(--accent) 10%, transparent); color: var(--accent)">Скопировано!</div>
          </div>

          <div id="import-panel" class="hidden">
            <p class="text-xs mb-3" style="color: var(--text-secondary)">
              Вставьте JSON или загрузите файл.
            </p>
            <textarea
              id="import-json"
              rows={4}
              class="w-full px-4 py-3 rounded-xl border text-xs outline-none resize-y mb-3 transition-colors"
              style="background-color: var(--bg-primary); color: var(--text-primary); border-color: var(--border); font-family: 'SF Mono', 'Fira Code', monospace"
              placeholder='{"theme":"dark","accent":"#ff5252","font":"inter","animations":true}'
            ></textarea>
            <div class="flex gap-3">
              <button
                id="import-btn"
                class="flex-1 py-2.5 text-sm font-semibold rounded-xl transition-all duration-200 hover-lift"
                style="background-color: var(--accent); color: var(--text-on-accent)"
              >
                Применить
              </button>
              <label
                class="flex-1 py-2.5 text-sm font-semibold rounded-xl text-center cursor-pointer border-2 transition-all duration-200 hover-lift"
                style="border-color: var(--accent); color: var(--accent)"
              >
                Загрузить файл
                <input type="file" id="import-file" accept=".json" class="hidden" />
              </label>
            </div>
            <div id="import-toast" class="hidden mt-2 text-sm text-center font-medium py-2 px-4 rounded-lg" style="background-color: color-mix(in srgb, var(--accent) 10%, transparent); color: var(--accent)">Тема применена!</div>
            <div id="import-error" class="hidden mt-2 text-sm text-center font-medium py-2 px-4 rounded-lg" style="background-color: color-mix(in srgb, #e53935 10%, transparent); color: #e53935">Ошибка: неверный формат JSON</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    import { initTheme, getStoredTheme, getStoredAccent, getStoredFont, getStoredAnimations, getStoredShadows, getStoredScrollbar, getStoredRadius, getStoredFontWeight, getStoredCustomFont, getStoredGradientEnabled, getStoredGradientIntensity, getStoredGradientFrom, getStoredGradientTo, getStoredSmoothScroll, setTheme, setAccent, setFont, setFontWeight, setCustomFont, loadGoogleFont, setAnimations, setShadows, setScrollbar, setRadius, resetSettings, getAccentColor, exportTheme, importTheme, setGradientEnabled, setGradientIntensity, setGradientFrom, setGradientTo, setSmoothScroll, applyGradient, darken, type Theme, type Font } from '../utils/themeStore'

    function syncUI(): void {
      const theme = getStoredTheme()
      const accent = getStoredAccent()
      const font = getStoredFont()

      document.querySelectorAll('.theme-btn').forEach((btn) => {
        const val = btn.getAttribute('data-theme-value')
        const isActive = val === theme
        if (isActive) {
          btn.classList.remove('border-transparent', 'opacity-60')
          btn.classList.add('border-[var(--accent)]')
          btn.style.backgroundColor = 'var(--accent)'
          btn.style.color = 'var(--text-on-accent)'
        } else {
          btn.classList.remove('border-[var(--accent)]')
          btn.classList.add('border-transparent', 'opacity-60')
          btn.style.backgroundColor = 'var(--bg-secondary)'
          btn.style.color = 'var(--text-primary)'
        }
      })

      document.querySelectorAll('.preset-btn').forEach((btn) => {
        const val = btn.getAttribute('data-accent-value')
        const isActive = val === accent
        const theme = getStoredTheme()
        const color = btn.getAttribute(theme === 'light' ? 'data-light' : 'data-dark') || ''
        ;(btn as HTMLElement).style.setProperty('--accent-color', color)
        if (isActive) {
          btn.classList.remove('border-transparent', 'opacity-60')
          btn.classList.add('border-[var(--accent)]', 'scale-110')
        } else {
          btn.classList.remove('border-[var(--accent)]', 'scale-110')
          btn.classList.add('border-transparent', 'opacity-60')
        }
      })

      document.querySelectorAll('.font-btn').forEach((btn) => {
        const val = btn.getAttribute('data-font-value')
        const isActive = val === font
        if (isActive) {
          btn.classList.remove('border-transparent', 'opacity-60')
          btn.classList.add('border-[var(--accent)]')
          btn.style.backgroundColor = 'var(--accent)'
          btn.style.color = 'var(--text-on-accent)'
        } else {
          btn.classList.remove('border-[var(--accent)]')
          btn.classList.add('border-transparent', 'opacity-60')
          btn.style.backgroundColor = 'var(--bg-secondary)'
          btn.style.color = 'var(--text-primary)'
        }
      })

      const animToggle = document.getElementById('anim-toggle') as HTMLElement | null
      const animKnob = document.getElementById('anim-knob') as HTMLElement | null
      const animations = getStoredAnimations()
      if (animToggle) {
        animToggle.setAttribute('aria-checked', animations.toString())
        animToggle.style.backgroundColor = animations ? 'var(--accent)' : 'var(--border)'
      }
      if (animKnob) animKnob.style.transform = animations ? 'translateX(24px)' : 'translateX(0)'

      const shadowToggle = document.getElementById('shadow-toggle') as HTMLElement | null
      const shadowKnob = document.getElementById('shadow-knob') as HTMLElement | null
      const shadows = getStoredShadows()
      if (shadowToggle) {
        shadowToggle.setAttribute('aria-checked', shadows.toString())
        shadowToggle.style.backgroundColor = shadows ? 'var(--accent)' : 'var(--border)'
      }
      if (shadowKnob) shadowKnob.style.transform = shadows ? 'translateX(24px)' : 'translateX(0)'

      const scrollbarToggle = document.getElementById('scrollbar-toggle') as HTMLElement | null
      const scrollbarKnob = document.getElementById('scrollbar-knob') as HTMLElement | null
      const scrollbar = getStoredScrollbar()
      if (scrollbarToggle) {
        scrollbarToggle.setAttribute('aria-checked', scrollbar.toString())
        scrollbarToggle.style.backgroundColor = scrollbar ? 'var(--accent)' : 'var(--border)'
      }
      if (scrollbarKnob) scrollbarKnob.style.transform = scrollbar ? 'translateX(24px)' : 'translateX(0)'

      const smoothScrollToggle = document.getElementById('smooth-scroll-toggle') as HTMLElement | null
      const smoothScrollKnob = document.getElementById('smooth-scroll-knob') as HTMLElement | null
      const smooth = getStoredSmoothScroll()
      if (smoothScrollToggle) {
        smoothScrollToggle.setAttribute('aria-checked', smooth.toString())
        smoothScrollToggle.style.backgroundColor = smooth ? 'var(--accent)' : 'var(--border)'
      }
      if (smoothScrollKnob) smoothScrollKnob.style.transform = smooth ? 'translateX(24px)' : 'translateX(0)'

      const radius = getStoredRadius()

      const radiusBadge = document.getElementById('radius-badge')
      if (radiusBadge) radiusBadge.textContent = radius + 'px'

      document.querySelectorAll('.weight-btn').forEach((btn) => {
        const val = btn.getAttribute('data-weight-value')
        const isActive = parseInt(val || '400') === getStoredFontWeight()
        if (isActive) {
          btn.classList.remove('border-transparent')
          btn.classList.add('border-[var(--accent)]')
          btn.style.backgroundColor = 'var(--accent)'
          btn.style.color = 'var(--text-on-accent)'
        } else {
          btn.classList.remove('border-[var(--accent)]')
          btn.classList.add('border-transparent')
          btn.style.backgroundColor = 'var(--bg-secondary)'
          btn.style.color = 'var(--text-primary)'
        }
      })

      const customInput = document.getElementById('custom-font-input') as HTMLInputElement | null
      const storedFont = getStoredFont()
      if (customInput) {
        if (storedFont === 'custom') {
          customInput.value = getStoredCustomFont()
        } else {
          customInput.value = ''
        }
      }

      document.querySelectorAll('.radius-btn').forEach((btn) => {
        const val = btn.getAttribute('data-radius-value')
        const isActive = val === radius.toString() || (val === 'custom' && ![0, 8, 16].includes(radius))
        if (isActive) {
          btn.classList.remove('border-transparent')
          btn.classList.add('border-[var(--accent)]')
          btn.style.backgroundColor = 'var(--accent)'
          btn.style.color = 'var(--text-on-accent)'
        } else {
          btn.classList.remove('border-[var(--accent)]')
          btn.classList.add('border-transparent')
          btn.style.backgroundColor = 'var(--bg-secondary)'
          btn.style.color = 'var(--text-primary)'
        }
      })
      const radiusCustom = document.getElementById('radius-custom')
      const radiusSlider = document.getElementById('radius-slider') as HTMLInputElement | null
      const radiusOutput = document.getElementById('radius-value')
      const showCustom = ![0, 8, 16].includes(radius)
      if (radiusCustom) radiusCustom.classList.toggle('hidden', !showCustom)
      if (radiusSlider) radiusSlider.value = radius.toString()
      if (radiusOutput) radiusOutput.textContent = radius.toString()

      const gradientToggle = document.getElementById('gradient-toggle') as HTMLElement | null
      const gradientKnob = document.getElementById('gradient-knob') as HTMLElement | null
      const gradientSettings = document.getElementById('gradient-settings') as HTMLElement | null
      const gradientEnabled = getStoredGradientEnabled()
      if (gradientToggle) {
        gradientToggle.setAttribute('aria-checked', gradientEnabled.toString())
        gradientToggle.style.backgroundColor = gradientEnabled ? 'var(--accent)' : 'var(--border)'
      }
      if (gradientKnob) gradientKnob.style.transform = gradientEnabled ? 'translateX(24px)' : 'translateX(0)'
      if (gradientSettings) gradientSettings.classList.toggle('hidden', !gradientEnabled)

      const gradientIntensity = getStoredGradientIntensity()
      const gradientIntensitySlider = document.getElementById('gradient-intensity-slider') as HTMLInputElement | null
      const gradientIntensityValue = document.getElementById('gradient-intensity-value') as HTMLElement | null
      if (gradientIntensitySlider) gradientIntensitySlider.value = gradientIntensity.toString()
      if (gradientIntensityValue) gradientIntensityValue.textContent = gradientIntensity + '%'

      const gradientFrom = getStoredGradientFrom()
      const gradientTo = getStoredGradientTo()
      const gradientFromPicker = document.getElementById('gradient-from-picker') as HTMLInputElement | null
      const gradientFromHex = document.getElementById('gradient-from-hex') as HTMLInputElement | null
      const gradientToPicker = document.getElementById('gradient-to-picker') as HTMLInputElement | null
      const gradientToHex = document.getElementById('gradient-to-hex') as HTMLInputElement | null

      const accentColor = getAccentColor(getStoredAccent(), getStoredTheme())
      const hoverColor = accentColor.startsWith('#') ? darken(accentColor, getStoredTheme() === 'light' ? -30 : 20) : accentColor

      if (gradientFromPicker) gradientFromPicker.value = gradientFrom || accentColor
      if (gradientFromHex) gradientFromHex.value = gradientFrom || accentColor
      if (gradientToPicker) gradientToPicker.value = gradientTo || hoverColor
      if (gradientToHex) gradientToHex.value = gradientTo || hoverColor

      const picker = document.getElementById('color-picker') as HTMLInputElement | null
      const hexInput = document.getElementById('hex-input') as HTMLInputElement | null

      if (accent.startsWith('#')) {
        if (picker) picker.value = accent
        if (hexInput) hexInput.value = accent
      } else {
        const color = getAccentColor(accent, getStoredTheme())
        if (picker) picker.value = color
        if (hexInput) hexInput.value = color
      }

      const exportJson = document.getElementById('export-json') as HTMLTextAreaElement | null
      if (exportJson) exportJson.value = exportTheme()
    }

    document.addEventListener('DOMContentLoaded', () => {
      initTheme()
      syncUI()

      document.querySelectorAll('.theme-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const val = btn.getAttribute('data-theme-value') as Theme
          setTheme(val)
          syncUI()
        })
      })

      document.querySelectorAll('.preset-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const val = btn.getAttribute('data-accent-value') as string
          setAccent(val)
          syncUI()
        })
      })

      const picker = document.getElementById('color-picker') as HTMLInputElement | null
      const hexInput = document.getElementById('hex-input') as HTMLInputElement | null

      picker?.addEventListener('input', () => {
        const color = picker.value
        if (hexInput) hexInput.value = color
        setAccent(color)
        syncUI()
      })

      hexInput?.addEventListener('input', () => {
        let val = hexInput.value.trim()
        if (!val.startsWith('#')) val = '#' + val
        if (/^#[0-9a-f]{6}$/i.test(val)) {
          if (picker) picker.value = val
          setAccent(val)
          syncUI()
        }
      })

      hexInput?.addEventListener('blur', () => {
        let val = hexInput.value.trim()
        if (!val.startsWith('#')) val = '#' + val
        if (/^#[0-9a-f]{6}$/i.test(val)) {
          if (picker) picker.value = val
          setAccent(val)
          syncUI()
        } else {
          const accent = getStoredAccent()
          const color = accent.startsWith('#') ? accent : getAccentColor(accent, getStoredTheme())
          hexInput.value = color
        }
      })

      document.querySelectorAll('.font-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const val = btn.getAttribute('data-font-value') as Font
          setFont(val)
          syncUI()
        })
      })

      document.querySelectorAll('.weight-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const val = parseInt(btn.getAttribute('data-weight-value') || '400')
          setFontWeight(val)
          syncUI()
        })
      })

      const customFontApply = document.getElementById('custom-font-apply')
      const customFontInput = document.getElementById('custom-font-input') as HTMLInputElement | null
      function applyCustomFont(): void {
        const name = customFontInput?.value.trim()
        if (!name) return
        setCustomFont(name)
        loadGoogleFont(name)
        setFont('custom' as Font)
        syncUI()
      }
      customFontApply?.addEventListener('click', applyCustomFont)
      customFontInput?.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') applyCustomFont()
      })

      const animToggleEl = document.getElementById('anim-toggle') as HTMLElement | null
      const animKnobEl = document.getElementById('anim-knob') as HTMLElement | null
      animToggleEl?.addEventListener('click', () => {
        const current = animToggleEl.getAttribute('aria-checked') === 'true'
        const next = !current
        animToggleEl.setAttribute('aria-checked', next.toString())
        animToggleEl.style.backgroundColor = next ? 'var(--accent)' : 'var(--border)'
        if (animKnobEl) animKnobEl.style.transform = next ? 'translateX(24px)' : 'translateX(0)'
        setAnimations(next)
      })

      const shadowToggleEl = document.getElementById('shadow-toggle') as HTMLElement | null
      const shadowKnobEl = document.getElementById('shadow-knob') as HTMLElement | null
      shadowToggleEl?.addEventListener('click', () => {
        const current = shadowToggleEl.getAttribute('aria-checked') === 'true'
        const next = !current
        shadowToggleEl.setAttribute('aria-checked', next.toString())
        shadowToggleEl.style.backgroundColor = next ? 'var(--accent)' : 'var(--border)'
        if (shadowKnobEl) shadowKnobEl.style.transform = next ? 'translateX(24px)' : 'translateX(0)'
        setShadows(next)
      })

      const scrollbarToggleEl = document.getElementById('scrollbar-toggle') as HTMLElement | null
      const scrollbarKnobEl = document.getElementById('scrollbar-knob') as HTMLElement | null
      scrollbarToggleEl?.addEventListener('click', () => {
        const current = scrollbarToggleEl.getAttribute('aria-checked') === 'true'
        const next = !current
        scrollbarToggleEl.setAttribute('aria-checked', next.toString())
        scrollbarToggleEl.style.backgroundColor = next ? 'var(--accent)' : 'var(--border)'
        if (scrollbarKnobEl) scrollbarKnobEl.style.transform = next ? 'translateX(24px)' : 'translateX(0)'
        setScrollbar(next)
      })

      const smoothScrollToggleEl = document.getElementById('smooth-scroll-toggle') as HTMLElement | null
      const smoothScrollKnobEl = document.getElementById('smooth-scroll-knob') as HTMLElement | null
      smoothScrollToggleEl?.addEventListener('click', () => {
        const current = smoothScrollToggleEl.getAttribute('aria-checked') === 'true'
        const next = !current
        smoothScrollToggleEl.setAttribute('aria-checked', next.toString())
        smoothScrollToggleEl.style.backgroundColor = next ? 'var(--accent)' : 'var(--border)'
        if (smoothScrollKnobEl) smoothScrollKnobEl.style.transform = next ? 'translateX(24px)' : 'translateX(0)'
        setSmoothScroll(next)
      })

      document.querySelectorAll('.radius-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const val = btn.getAttribute('data-radius-value')
          if (val === 'custom') {
            const custom = document.getElementById('radius-custom')
            if (custom) custom.classList.toggle('hidden')
            return
          }
          const px = parseInt(val || '16')
          setRadius(px)
          syncUI()
        })
      })

      const radiusSlider = document.getElementById('radius-slider') as HTMLInputElement | null
      const radiusOutput = document.getElementById('radius-value')
      radiusSlider?.addEventListener('input', () => {
        const px = parseInt(radiusSlider.value)
        setRadius(px)
        if (radiusOutput) radiusOutput.textContent = px.toString()
        const badge = document.getElementById('radius-badge')
        if (badge) badge.textContent = px + 'px'
        document.querySelectorAll('.radius-btn').forEach((b) => {
          const isCustom = b.getAttribute('data-radius-value') === 'custom'
          const isActive = isCustom || b.getAttribute('data-radius-value') === px.toString()
          if (isCustom && isActive) {
            b.classList.remove('border-transparent')
            b.classList.add('border-[var(--accent)]')
            b.style.backgroundColor = 'var(--accent)'
            b.style.color = 'var(--text-on-accent)'
          } else if (b.getAttribute('data-radius-value') !== 'custom') {
            b.classList.remove('border-[var(--accent)]')
            b.classList.add('border-transparent')
            b.style.backgroundColor = 'var(--bg-secondary)'
            b.style.color = 'var(--text-primary)'
          }
        })
      })

      const resetBtn = document.getElementById('reset-btn')
      resetBtn?.addEventListener('click', () => {
        resetSettings()
        syncUI()
      })

      const exportJson = document.getElementById('export-json') as HTMLTextAreaElement
      const exportBtn = document.getElementById('export-btn')
      const exportToast = document.getElementById('export-toast')

      const importJson = document.getElementById('import-json') as HTMLTextAreaElement
      const importBtn = document.getElementById('import-btn')
      const importToast = document.getElementById('import-toast')
      const importError = document.getElementById('import-error')
      const importFile = document.getElementById('import-file') as HTMLInputElement

      const exportTabBtn = document.getElementById('export-tab-btn')
      const importTabBtn = document.getElementById('import-tab-btn')
      const exportPanel = document.getElementById('export-panel')
      const importPanel = document.getElementById('import-panel')

      exportTabBtn?.addEventListener('click', () => {
        exportPanel?.classList.remove('hidden')
        importPanel?.classList.add('hidden')
        if (exportJson) exportJson.value = exportTheme()
        exportTabBtn.style.backgroundColor = 'var(--accent)'
        exportTabBtn.style.color = 'var(--text-on-accent)'
        importTabBtn && (importTabBtn.style.backgroundColor = 'transparent')
        importTabBtn && (importTabBtn.style.color = 'var(--text-secondary)')
      })

      importTabBtn?.addEventListener('click', () => {
        exportPanel?.classList.add('hidden')
        importPanel?.classList.remove('hidden')
        importTabBtn.style.backgroundColor = 'var(--accent)'
        importTabBtn.style.color = 'var(--text-on-accent)'
        exportTabBtn && (exportTabBtn.style.backgroundColor = 'transparent')
        exportTabBtn && (exportTabBtn.style.color = 'var(--text-secondary)')
      })

      exportBtn?.addEventListener('click', () => {
        const text = exportTheme()
        navigator.clipboard?.writeText(text).catch(() => {
          if (exportJson) {
            exportJson.select()
            document.execCommand('copy')
          }
        })
        if (exportToast) {
          exportToast.classList.remove('hidden')
          setTimeout(() => exportToast.classList.add('hidden'), 3000)
        }
      })

      const downloadBtn = document.getElementById('download-btn')
      downloadBtn?.addEventListener('click', () => {
        const text = exportTheme()
        const blob = new Blob([text], { type: 'application/json' })
        const url = URL.createObjectURL(blob)
        const a = document.createElement('a')
        a.href = url
        a.download = 'protoland-theme.json'
        a.click()
        URL.revokeObjectURL(url)
      })

      importBtn?.addEventListener('click', () => {
        const text = importJson?.value.trim() ?? ''
        const ok = importTheme(text)
        if (ok) {
          initTheme()
          syncUI()
          importError?.classList.add('hidden')
          importToast?.classList.remove('hidden')
          setTimeout(() => importToast?.classList.add('hidden'), 3000)
        } else {
          importToast?.classList.add('hidden')
          importError?.classList.remove('hidden')
          setTimeout(() => importError?.classList.add('hidden'), 3000)
        }
      })

      importFile?.addEventListener('change', () => {
        const file = importFile.files?.[0]
        if (!file) return
        const reader = new FileReader()
        reader.onload = () => {
          const text = reader.result as string
          const ok = importTheme(text)
          if (ok) {
            initTheme()
            syncUI()
            if (importJson) importJson.value = text
            importError?.classList.add('hidden')
            importToast?.classList.remove('hidden')
            setTimeout(() => importToast?.classList.add('hidden'), 3000)
          } else {
            importToast?.classList.add('hidden')
            importError?.classList.remove('hidden')
            setTimeout(() => importError?.classList.add('hidden'), 3000)
          }
        }
        reader.readAsText(file)
        importFile.value = ''
      })

      const gradientToggleEl = document.getElementById('gradient-toggle') as HTMLElement | null
      const gradientKnobEl = document.getElementById('gradient-knob') as HTMLElement | null
      const gradientSettingsEl = document.getElementById('gradient-settings') as HTMLElement | null
      gradientToggleEl?.addEventListener('click', () => {
        const current = gradientToggleEl.getAttribute('aria-checked') === 'true'
        const next = !current
        gradientToggleEl.setAttribute('aria-checked', next.toString())
        gradientToggleEl.style.backgroundColor = next ? 'var(--accent)' : 'var(--border)'
        if (gradientKnobEl) gradientKnobEl.style.transform = next ? 'translateX(24px)' : 'translateX(0)'
        if (gradientSettingsEl) gradientSettingsEl.classList.toggle('hidden', !next)
        setGradientEnabled(next)
      })

      const gradientFromPicker = document.getElementById('gradient-from-picker') as HTMLInputElement | null
      const gradientFromHex = document.getElementById('gradient-from-hex') as HTMLInputElement | null
      const gradientToPicker = document.getElementById('gradient-to-picker') as HTMLInputElement | null
      const gradientToHex = document.getElementById('gradient-to-hex') as HTMLInputElement | null

      gradientFromPicker?.addEventListener('input', () => {
        const color = gradientFromPicker.value
        if (gradientFromHex) gradientFromHex.value = color
        setGradientFrom(color)
      })

      gradientFromHex?.addEventListener('input', () => {
        let val = gradientFromHex.value.trim()
        if (!val.startsWith('#')) val = '#' + val
        if (/^#[0-9a-f]{6}$/i.test(val)) {
          if (gradientFromPicker) gradientFromPicker.value = val
          setGradientFrom(val)
        }
      })

      gradientFromHex?.addEventListener('blur', () => {
        let val = gradientFromHex.value.trim()
        if (!val.startsWith('#')) val = '#' + val
        if (!/^#[0-9a-f]{6}$/i.test(val)) {
          const stored = getStoredGradientFrom()
          const fallback = stored || getAccentColor(getStoredAccent(), getStoredTheme())
          gradientFromHex.value = fallback
        }
      })

      gradientToPicker?.addEventListener('input', () => {
        const color = gradientToPicker.value
        if (gradientToHex) gradientToHex.value = color
        setGradientTo(color)
      })

      gradientToHex?.addEventListener('input', () => {
        let val = gradientToHex.value.trim()
        if (!val.startsWith('#')) val = '#' + val
        if (/^#[0-9a-f]{6}$/i.test(val)) {
          if (gradientToPicker) gradientToPicker.value = val
          setGradientTo(val)
        }
      })

      gradientToHex?.addEventListener('blur', () => {
        let val = gradientToHex.value.trim()
        if (!val.startsWith('#')) val = '#' + val
        if (!/^#[0-9a-f]{6}$/i.test(val)) {
          const stored = getStoredGradientTo()
          const accentColor = getAccentColor(getStoredAccent(), getStoredTheme())
          const fallback = stored || darken(accentColor, getStoredTheme() === 'light' ? -30 : 20)
          gradientToHex.value = fallback
        }
      })

      const gradientIntensitySlider = document.getElementById('gradient-intensity-slider') as HTMLInputElement | null
      const gradientIntensityValue = document.getElementById('gradient-intensity-value') as HTMLElement | null
      gradientIntensitySlider?.addEventListener('input', () => {
        const val = parseInt(gradientIntensitySlider.value)
        if (gradientIntensityValue) gradientIntensityValue.textContent = val + '%'
        setGradientIntensity(val)
      })
    })
  </script>
</BaseLayout>