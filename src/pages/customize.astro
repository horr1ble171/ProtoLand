---
import BaseLayout from '../layouts/BaseLayout.astro'
import Icon from '../components/UI/Icon.astro'

const presetColors = [
  { value: 'red', label: 'Красный', light: '#e53935', dark: '#ff5252' },
  { value: 'green', label: 'Зелёный', light: '#2e7d32', dark: '#4caf50' },
  { value: 'blue', label: 'Синий', light: '#1565c0', dark: '#42a5f5' },
]
---

<BaseLayout title="ProtoLand — Настройка лендинга" description="Настройте внешний вид лендинга: выберите тему и акцентный цвет.">
  <div class="min-h-screen" style="background-color: var(--bg-primary); color: var(--text-primary)">
    <div class="max-w-2xl mx-auto px-4 py-12">
      <a
        href="/"
        class="inline-flex items-center gap-2 text-sm font-medium mb-8 transition-colors hover:text-[var(--accent)]"
        style="color: var(--text-secondary)"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><polyline points="12 19 5 12 12 5"/></svg>
        На главную
      </a>

      <h1 class="text-3xl md:text-4xl font-bold mb-2">Настройка лендинга</h1>
      <p class="text-base mb-10" style="color: var(--text-secondary)">
        Выберите цветовую схему и акцентный цвет — изменения сразу применяются и сохраняются.
      </p>

      <div class="space-y-8" id="customize-app">
        <div class="rounded-2xl p-6 border" style="background-color: var(--bg-card); border-color: var(--border)">
          <h2 class="text-xl font-bold mb-4">Тема оформления</h2>
          <div class="flex gap-3">
            <button
              class="theme-btn flex-1 flex items-center justify-center gap-3 px-6 py-4 rounded-xl border-2 font-semibold transition-all duration-200"
              data-theme-value="light"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
              Светлая
            </button>
            <button
              class="theme-btn flex-1 flex items-center justify-center gap-3 px-6 py-4 rounded-xl border-2 font-semibold transition-all duration-200"
              data-theme-value="dark"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
              Тёмная
            </button>
          </div>
        </div>

        <div class="rounded-2xl p-6 border" style="background-color: var(--bg-card); border-color: var(--border)">
          <h2 class="text-xl font-bold mb-4">Акцентный цвет</h2>

          <div class="mb-6">
            <p class="text-sm font-medium mb-3" style="color: var(--text-secondary)">Быстрый выбор</p>
            <div class="flex gap-3 flex-wrap">
              {presetColors.map((c) => (
                <button
                  class="preset-btn w-10 h-10 rounded-full border-2 transition-all duration-200 hover:scale-110"
                  data-accent-value={c.value}
                  aria-label={c.label}
                  style="background-color: var(--accent-color)"
                  data-light={c.light}
                  data-dark={c.dark}
                />
              ))}
            </div>
          </div>

          <div class="border-t pt-6" style="border-color: var(--border)">
            <p class="text-sm font-medium mb-3" style="color: var(--text-secondary)">Произвольный цвет</p>
            <div class="flex items-center gap-4">
              <div class="relative">
                <input
                  type="color"
                  id="color-picker"
                  class="w-14 h-14 rounded-xl border-2 cursor-pointer"
                  style="border-color: var(--border); background: none; padding: 2px"
                  value="#e53935"
                />
              </div>
              <div class="flex-1">
                <label for="hex-input" class="text-xs font-medium block mb-1" style="color: var(--text-secondary)">HEX</label>
                <input
                  type="text"
                  id="hex-input"
                  class="w-full px-4 py-2.5 rounded-xl border font-mono text-sm outline-none transition-colors"
                  style="background-color: var(--bg-primary); color: var(--text-primary); border-color: var(--border)"
                  placeholder="#e53935"
                  maxlength={7}
                />
              </div>
            </div>
          </div>
        </div>

        <div class="rounded-2xl p-6 border" style="background-color: var(--bg-card); border-color: var(--border)">
          <h2 class="text-xl font-bold mb-4">Шрифт</h2>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
            <button class="font-btn flex flex-col items-center gap-2 px-4 py-4 rounded-xl border-2 font-semibold transition-all duration-200" data-font-value="system">
              <span class="text-lg">System</span>
              <span class="text-xs opacity-60">Системный</span>
            </button>
            <button class="font-btn flex flex-col items-center gap-2 px-4 py-4 rounded-xl border-2 font-semibold transition-all duration-200" data-font-value="inter" style="font-family: Inter">
              <span class="text-lg">Inter</span>
              <span class="text-xs opacity-60">Современный</span>
            </button>
            <button class="font-btn flex flex-col items-center gap-2 px-4 py-4 rounded-xl border-2 font-semibold transition-all duration-200" data-font-value="roboto" style="font-family: Roboto">
              <span class="text-lg">Roboto</span>
              <span class="text-xs opacity-60">Классика</span>
            </button>
            <button class="font-btn flex flex-col items-center gap-2 px-4 py-4 rounded-xl border-2 font-semibold transition-all duration-200" data-font-value="playfair" style="font-family: 'Playfair Display'">
              <span class="text-lg">Playfair</span>
              <span class="text-xs opacity-60">Премиум</span>
            </button>
          </div>
        </div>

        <div class="rounded-2xl p-6 border" style="background-color: var(--bg-card); border-color: var(--border)">
          <h2 class="text-xl font-bold mb-4">Анимации</h2>
          <div class="flex items-center justify-between">
            <div>
              <p class="font-medium" style="color: var(--text-primary)">Fade-in при скролле</p>
              <p class="text-sm" style="color: var(--text-secondary)">Плавное появление секций при прокрутке</p>
            </div>
            <button
              id="anim-toggle"
              class="relative w-14 h-7 rounded-full transition-colors duration-200"
              style="background-color: var(--toggle-bg, var(--border))"
              role="switch"
              aria-checked="true"
            >
              <span id="anim-knob" class="absolute top-0.5 left-0.5 w-6 h-6 rounded-full bg-white shadow transition-transform duration-200" style="transform: translateX(0)" />
            </button>
          </div>
        </div>

        <div class="rounded-2xl p-6 border" style="background-color: var(--bg-card); border-color: var(--border)">
          <h2 class="text-xl font-bold mb-4">Предпросмотр</h2>
          <div class="flex flex-wrap gap-3">
            <span class="px-5 py-2.5 rounded-xl font-semibold text-sm transition-all" style="background-color: var(--accent); color: var(--text-on-accent)">
              Кнопка с акцентом
            </span>
            <span class="px-5 py-2.5 rounded-xl font-semibold text-sm border-2 transition-all" style="border-color: var(--accent); color: var(--accent)">
              Контурная кнопка
            </span>
            <span class="px-5 py-2.5 rounded-xl text-sm transition-all" style="background-color: var(--bg-secondary); color: var(--text-primary)">
              Обычный фон
            </span>
            <span class="px-5 py-2.5 rounded-xl text-sm transition-all" style="background-color: var(--bg-secondary); color: var(--text-secondary)">
              Вторичный текст
            </span>
          </div>
          <div class="mt-4 h-2 rounded-full transition-all" style="background-color: var(--accent)" />
        </div>

        <div class="rounded-2xl p-6 border" style="background-color: var(--bg-card); border-color: var(--border)">
          <div class="flex gap-1 mb-4">
            <button id="export-tab-btn" class="flex-1 py-2.5 text-sm font-semibold rounded-lg transition-all" style="background-color: var(--accent); color: var(--text-on-accent)">Экспорт</button>
            <button id="import-tab-btn" class="flex-1 py-2.5 text-sm font-semibold rounded-lg transition-all" style="background-color: var(--bg-secondary); color: var(--text-secondary)">Импорт</button>
          </div>

          <div id="export-panel">
            <p class="text-sm mb-3" style="color: var(--text-secondary)">
              Скопируйте JSON и отправьте разработчику.
            </p>
            <textarea
              id="export-json"
              rows={5}
              class="w-full px-4 py-3 rounded-xl border text-xs font-mono outline-none resize-y mb-3 transition-colors"
              style="background-color: var(--bg-primary); color: var(--text-primary); border-color: var(--border)"
              readonly
            ></textarea>
            <div class="flex gap-3">
              <button
                id="export-btn"
                class="flex-1 py-3 text-base font-semibold rounded-xl text-[var(--text-on-accent)] bg-[var(--accent)] hover:bg-[var(--accent-hover)] transition-all duration-200"
              >
                Копировать
              </button>
              <button
                id="download-btn"
                class="flex-1 py-3 text-base font-semibold rounded-xl text-[var(--accent)] border-2 border-[var(--accent)] hover:bg-[var(--accent)] hover:text-[var(--text-on-accent)] transition-all duration-200"
              >
                Скачать JSON
              </button>
            </div>
            <div id="export-toast" class="hidden mt-2 text-sm text-center font-medium py-2 px-4 rounded-lg" style="background-color: var(--bg-secondary); color: var(--accent)">Скопировано!</div>
          </div>

          <div id="import-panel" class="hidden">
            <p class="text-sm mb-3" style="color: var(--text-secondary)">
              Вставьте JSON или загрузите файл.
            </p>
            <textarea
              id="import-json"
              rows={5}
              class="w-full px-4 py-3 rounded-xl border text-xs font-mono outline-none resize-y mb-3 transition-colors"
              style="background-color: var(--bg-primary); color: var(--text-primary); border-color: var(--border)"
              placeholder='{"theme":"dark","accent":"#ff5252","font":"inter","animations":true}'
            ></textarea>
            <div class="flex gap-3">
              <button
                id="import-btn"
                class="flex-1 py-3 text-base font-semibold rounded-xl text-[var(--text-on-accent)] bg-[var(--accent)] hover:bg-[var(--accent-hover)] transition-all duration-200"
              >
                Применить
              </button>
              <label
                class="flex-1 py-3 text-base font-semibold rounded-xl text-center cursor-pointer border-2 transition-all duration-200"
                style="border-color: var(--accent); color: var(--accent)"
              >
                Загрузить файл
                <input type="file" id="import-file" accept=".json" class="hidden" />
              </label>
            </div>
            <div id="import-toast" class="hidden mt-2 text-sm text-center font-medium py-2 px-4 rounded-lg" style="background-color: var(--bg-secondary); color: var(--accent)">Тема применена!</div>
            <div id="import-error" class="hidden mt-2 text-sm text-center font-medium py-2 px-4 rounded-lg" style="background-color: var(--bg-secondary); color: #e53935">Ошибка: неверный формат JSON</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    import { initTheme, getStoredTheme, getStoredAccent, getStoredFont, getStoredAnimations, setTheme, setAccent, setFont, setAnimations, getAccentColor, exportTheme, importTheme, type Theme, type Font } from '../utils/themeStore'

    function syncUI(): void {
      const theme = getStoredTheme()
      const accent = getStoredAccent()
      const font = getStoredFont()

      document.querySelectorAll('.theme-btn').forEach((btn) => {
        const val = btn.getAttribute('data-theme-value')
        const isActive = val === theme
        if (isActive) {
          btn.classList.remove('border-transparent', 'opacity-60')
          btn.classList.add('border-[var(--accent)]')
          btn.style.backgroundColor = 'var(--accent)'
          btn.style.color = 'var(--text-on-accent)'
        } else {
          btn.classList.remove('border-[var(--accent)]')
          btn.classList.add('border-transparent', 'opacity-60')
          btn.style.backgroundColor = 'var(--bg-secondary)'
          btn.style.color = 'var(--text-primary)'
        }
      })

      document.querySelectorAll('.preset-btn').forEach((btn) => {
        const val = btn.getAttribute('data-accent-value')
        const isActive = val === accent
        const theme = getStoredTheme()
        const color = btn.getAttribute(theme === 'light' ? 'data-light' : 'data-dark') || ''
        ;(btn as HTMLElement).style.setProperty('--accent-color', color)
        if (isActive) {
          btn.classList.remove('border-transparent', 'opacity-60')
          btn.classList.add('border-[var(--accent)]', 'scale-110')
        } else {
          btn.classList.remove('border-[var(--accent)]', 'scale-110')
          btn.classList.add('border-transparent', 'opacity-60')
        }
      })

      document.querySelectorAll('.font-btn').forEach((btn) => {
        const val = btn.getAttribute('data-font-value')
        const isActive = val === font
        if (isActive) {
          btn.classList.remove('border-transparent', 'opacity-60')
          btn.classList.add('border-[var(--accent)]')
          btn.style.backgroundColor = 'var(--accent)'
          btn.style.color = 'var(--text-on-accent)'
        } else {
          btn.classList.remove('border-[var(--accent)]')
          btn.classList.add('border-transparent', 'opacity-60')
          btn.style.backgroundColor = 'var(--bg-secondary)'
          btn.style.color = 'var(--text-primary)'
        }
      })

      const animToggle = document.getElementById('anim-toggle') as HTMLElement | null
      const animKnob = document.getElementById('anim-knob') as HTMLElement | null
      const animations = getStoredAnimations()
      if (animToggle) {
        animToggle.setAttribute('aria-checked', animations.toString())
        animToggle.style.backgroundColor = animations ? 'var(--accent)' : 'var(--border)'
      }
      if (animKnob) animKnob.style.transform = animations ? 'translateX(28px)' : 'translateX(0)'

      const picker = document.getElementById('color-picker') as HTMLInputElement | null
      const hexInput = document.getElementById('hex-input') as HTMLInputElement | null

      if (accent.startsWith('#')) {
        if (picker) picker.value = accent
        if (hexInput) hexInput.value = accent
      } else {
        const color = getAccentColor(accent, getStoredTheme())
        if (picker) picker.value = color
        if (hexInput) hexInput.value = color
      }

      const exportJson = document.getElementById('export-json') as HTMLTextAreaElement | null
      if (exportJson) exportJson.value = exportTheme()
    }

    document.addEventListener('DOMContentLoaded', () => {
      initTheme()
      syncUI()

      document.querySelectorAll('.theme-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const val = btn.getAttribute('data-theme-value') as Theme
          setTheme(val)
          syncUI()
        })
      })

      document.querySelectorAll('.preset-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const val = btn.getAttribute('data-accent-value') as string
          setAccent(val)
          syncUI()
        })
      })

      const picker = document.getElementById('color-picker') as HTMLInputElement | null
      const hexInput = document.getElementById('hex-input') as HTMLInputElement | null

      picker?.addEventListener('input', () => {
        const color = picker.value
        if (hexInput) hexInput.value = color
        setAccent(color)
        syncUI()
      })

      hexInput?.addEventListener('input', () => {
        let val = hexInput.value.trim()
        if (!val.startsWith('#')) val = '#' + val
        if (/^#[0-9a-f]{6}$/i.test(val)) {
          if (picker) picker.value = val
          setAccent(val)
          syncUI()
        }
      })

      hexInput?.addEventListener('blur', () => {
        let val = hexInput.value.trim()
        if (!val.startsWith('#')) val = '#' + val
        if (/^#[0-9a-f]{6}$/i.test(val)) {
          if (picker) picker.value = val
          setAccent(val)
          syncUI()
        } else {
          const accent = getStoredAccent()
          const color = accent.startsWith('#') ? accent : getAccentColor(accent, getStoredTheme())
          hexInput.value = color
        }
      })

      document.querySelectorAll('.font-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const val = btn.getAttribute('data-font-value') as Font
          setFont(val)
          syncUI()
        })
      })

      const animToggleEl = document.getElementById('anim-toggle') as HTMLElement | null
      const animKnobEl = document.getElementById('anim-knob') as HTMLElement | null
      animToggleEl?.addEventListener('click', () => {
        const current = animToggleEl.getAttribute('aria-checked') === 'true'
        const next = !current
        animToggleEl.setAttribute('aria-checked', next.toString())
        if (animKnobEl) animKnobEl.style.transform = next ? 'translateX(28px)' : 'translateX(0)'
        setAnimations(next)
      })

      const exportJson = document.getElementById('export-json') as HTMLTextAreaElement
      const exportBtn = document.getElementById('export-btn')
      const exportToast = document.getElementById('export-toast')

      const importJson = document.getElementById('import-json') as HTMLTextAreaElement
      const importBtn = document.getElementById('import-btn')
      const importToast = document.getElementById('import-toast')
      const importError = document.getElementById('import-error')
      const importFile = document.getElementById('import-file') as HTMLInputElement

      const exportTabBtn = document.getElementById('export-tab-btn')
      const importTabBtn = document.getElementById('import-tab-btn')
      const exportPanel = document.getElementById('export-panel')
      const importPanel = document.getElementById('import-panel')

      exportTabBtn?.addEventListener('click', () => {
        exportPanel?.classList.remove('hidden')
        importPanel?.classList.add('hidden')
        if (exportJson) exportJson.value = exportTheme()
        exportTabBtn.style.backgroundColor = 'var(--accent)'
        exportTabBtn.style.color = 'var(--text-on-accent)'
        importTabBtn && (importTabBtn.style.backgroundColor = 'var(--bg-secondary)')
        importTabBtn && (importTabBtn.style.color = 'var(--text-secondary)')
      })

      importTabBtn?.addEventListener('click', () => {
        exportPanel?.classList.add('hidden')
        importPanel?.classList.remove('hidden')
        importTabBtn.style.backgroundColor = 'var(--accent)'
        importTabBtn.style.color = 'var(--text-on-accent)'
        exportTabBtn && (exportTabBtn.style.backgroundColor = 'var(--bg-secondary)')
        exportTabBtn && (exportTabBtn.style.color = 'var(--text-secondary)')
      })

      exportBtn?.addEventListener('click', () => {
        const text = exportTheme()
        navigator.clipboard?.writeText(text).catch(() => {
          if (exportJson) {
            exportJson.select()
            document.execCommand('copy')
          }
        })
        if (exportToast) {
          exportToast.classList.remove('hidden')
          setTimeout(() => exportToast.classList.add('hidden'), 3000)
        }
      })

      const downloadBtn = document.getElementById('download-btn')
      downloadBtn?.addEventListener('click', () => {
        const text = exportTheme()
        const blob = new Blob([text], { type: 'application/json' })
        const url = URL.createObjectURL(blob)
        const a = document.createElement('a')
        a.href = url
        a.download = 'protoland-theme.json'
        a.click()
        URL.revokeObjectURL(url)
      })

      importBtn?.addEventListener('click', () => {
        const text = importJson?.value.trim() ?? ''
        const ok = importTheme(text)
        if (ok) {
          initTheme()
          syncUI()
          importError?.classList.add('hidden')
          importToast?.classList.remove('hidden')
          setTimeout(() => importToast?.classList.add('hidden'), 3000)
        } else {
          importToast?.classList.add('hidden')
          importError?.classList.remove('hidden')
          setTimeout(() => importError?.classList.add('hidden'), 3000)
        }
      })

      importFile?.addEventListener('change', () => {
        const file = importFile.files?.[0]
        if (!file) return
        const reader = new FileReader()
        reader.onload = () => {
          const text = reader.result as string
          const ok = importTheme(text)
          if (ok) {
            initTheme()
            syncUI()
            if (importJson) importJson.value = text
            importError?.classList.add('hidden')
            importToast?.classList.remove('hidden')
            setTimeout(() => importToast?.classList.add('hidden'), 3000)
          } else {
            importToast?.classList.add('hidden')
            importError?.classList.remove('hidden')
            setTimeout(() => importError?.classList.add('hidden'), 3000)
          }
        }
        reader.readAsText(file)
        importFile.value = ''
      })
    })
  </script>
</BaseLayout>
